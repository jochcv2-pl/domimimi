# ============================================================
# Domipack — Variables d'environnement PRODUCTION
# ============================================================
# Copier ce fichier vers .env et remplir les valeurs :
#   cp .env.production.example .env
#   nano .env
# NE JAMAIS committer .env dans Git.
# Générer les secrets avec: openssl rand -base64 32
# ============================================================

# ─── Base de données ───
# Docker Compose construit DATABASE_URL automatiquement pour le conteneur app
# à partir de ces 3 variables. Mais les commandes CLI (prisma db push, seed)
# tournent sur le host et ont besoin de DATABASE_URL ci-dessous.
POSTGRES_USER=domipack
POSTGRES_PASSWORD=CHANGER_MOT_DE_PASSE_FORT_ICI
POSTGRES_DB=domipack

# URL de connexion pour les CLI (prisma, seed) depuis le host vers le DB Docker.
# Le port 5433 est exposé en localhost uniquement (cf docker-compose.prod.yml).
# Remplacez le mot de passe par la valeur de POSTGRES_PASSWORD ci-dessus.
DATABASE_URL=postgresql://domipack:CHANGER_MOT_DE_PASSE_FORT_ICI@localhost:5433/domipack?schema=public

# ─── Authentification ───
AUTH_SECRET=GENERER_UN_SECRET_DE_32_CARACTERES_MINIMUM
AUTH_URL=https://domipack.fr
NEXTAUTH_URL=https://domipack.fr

# ─── Cron pipeline ───
CRON_SECRET=GENERER_UN_SECRET_DIFFERENT

# ─── Site public ───
NEXT_PUBLIC_SITE_URL=https://domipack.fr

# ─── Analytics (Umami self-hosted) ───
# Laisser NEXT_PUBLIC_UMAMI_WEBSITE_ID vide au premier déploiement.
# Après avoir configuré Umami (/analytics), y coller le Website ID et restart l'app.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=CHANGER_MOT_DE_PASSE_UMAMI
UMAMI_DB_NAME=umami
UMAMI_APP_SECRET=GENERER_SECRET_UMAMI

# ════════════════════════════════════════════════════════════
# TOUT LE RESTE est configurable depuis l'admin CRM :
#   - Nom de marque + logo       → CMS → Identité de marque
#   - Email provider + SMTP      → Configuration → Passerelles d'envoi
#   - Clé API IA                 → Configuration → Modèle d'IA
#   - Contact WhatsApp/Messenger → CMS → Boutons de contact
#   - Contenu du site            → CMS → Hero / Avantages / etc.
# ════════════════════════════════════════════════════════════
