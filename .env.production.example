# ============================================================
# Domipack — Variables d'environnement PRODUCTION
# ============================================================
# Copier ce fichier vers .env.production et remplir les valeurs.
# NE JAMAIS committer .env.production dans Git.
#
# Générer les secrets avec: openssl rand -base64 32
# ============================================================

# ─── Base de données ───
POSTGRES_USER=domipack
POSTGRES_PASSWORD=CHANGER_MOT_DE_PASSE_FORT_ICI
POSTGRES_DB=domipack
# DATABASE_URL est construit automatiquement par docker-compose (voir app.environment)
# Mais il doit aussi être disponible pour les scripts Prisma (migrate, studio)
DATABASE_URL=postgresql://domipack:CHANGER_MOT_DE_PASSE_FORT_ICI@localhost:5432/domipack?schema=public

# ─── Authentification ───
# Générer: openssl rand -base64 32
AUTH_SECRET=GENERER_UN_SECRET_DE_32_CARACTERES_MINIMUM
# En production: votre domaine réel
AUTH_URL=https://domipack.fr
NEXTAUTH_URL=https://domipack.fr

# ─── Secrets API ───
# Pour le cron pipeline email
CRON_SECRET=GENERER_UN_SECRET_DIFFERENT
# Pour l'authentification API admin (legacy/backup)
ADMIN_API_KEY=GENERER_UNE_CLE_DIFFERENTE

# ─── Email pipeline ───
# Provider actif: resend | brevo | smtp
EMAIL_PROVIDER_ACTIVE=resend
EMAIL_RESEND_API_KEY=
EMAIL_BREVO_API_KEY=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=noreply@domipack.fr
EMAIL_FROM_NAME=Domipack
NOTIFY_EMAIL_TO=contact@domipack.fr

# ─── IA (tri candidatures) ───
AI_API_KEY=
AI_ENDPOINT=http://localhost:11434
AI_MODEL=qwen3-8b
AI_PROVIDER=ollama

# ─── Site public ───
NEXT_PUBLIC_SITE_URL=https://domipack.fr

# ─── Analytics (Umami self-hosted) ───
# Website ID créé dans le dashboard Umami (/analytics)
# Laisser vide pour désactiver le tracking
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=CHANGER_MOT_DE_PASSE_UMAMI
UMAMI_DB_NAME=umami
UMAMI_APP_SECRET=GENERER_SECRET_UMAMI

# ─── Contact (CMS settings) ───
CONTACT_WHATSAPP=
CONTACT_MESSENGER=
