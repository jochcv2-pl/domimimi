# Domipack — .dockerignore
# Évite d'envoyer des fichiers inutiles au contexte de build Docker.

node_modules
.next
.git
.gitignore
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store

# Tests & CI (pas nécessaires dans l'image prod)
tests
*.test.ts
*.test.tsx
vitest.config.ts
.github
.husky
e2e-pipeline-test.mjs

# Docs & audits
docs
audits
README.md
*.md

# Scripts dev (prisma seeds ne tournent pas en prod)
prisma/seed.mjs
prisma/seed-admin.mjs
prisma/migrate-to-pipe.mjs

# Env files (jamais dans l'image)
.env
.env.*
!.env.example

# OS / IDE
.DS_Store
Thumbs.db
.vscode
.idea

# Certbot (créé par root, permissions bloquent le build)
certbot-etc
certbot-web

# Backups & uploads
backups
public/uploads
