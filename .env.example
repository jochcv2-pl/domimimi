# Domipack — Variables d'environnement
#
# Copier ce fichier en .env et remplir les valeurs :
#   cp .env.example .env       (Linux/macOS)
#   Copy-Item .env.example .env (Windows PowerShell)
#
# ⚠️  Ne JAMAIS committer le fichier .env (déjà dans .gitignore).

# ============================================================
# BASE DE DONNÉES (obligatoire)
# ============================================================
# Format : postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
# En dev : PostgreSQL Docker sur le port 5433 (cf docker-compose.yml)
DATABASE_URL="postgresql://domipack:domipack_dev@localhost:5433/domipack?schema=public"

# ============================================================
# AUTHENTIFICATION (obligatoire)
# ============================================================
# Secret utilisé pour signer les sessions NextAuth.
# Générer via : pnpm exec auth secret
# Ou via : openssl rand -base64 32
AUTH_SECRET="REMPLACER_PAR_UNE_CHAINE_ALEATOIRE_32_OCTETS"

# ============================================================
# PIPELINE EMAIL (obligatoire pour activer le cron)
# ============================================================
# Secret partagé pour authentifier les appels du cron externe vers
# /api/cron/process-emails. Sans cette variable, l'endpoint refuse
# tout appel (HTTP 500 CRON_NOT_CONFIGURED).
# À mettre aussi dans la config du cron systemd / Task Scheduler / Vercel.
CRON_SECRET="REMPLACER_PAR_UNE_CHAINE_ALEATOIRE_32_OCTETS"

# ============================================================
# CLÉ API ADMIN LEGACY (optionnel — à déprécier)
# ============================================================
# Ancienne clé API utilisée par certaines routes admin sans session.
# Préférer l'authentification NextAuth via /login.
ADMIN_API_KEY="dev-admin-key-2026"

# ============================================================
# NOTIFICATIONS INTERNES (optionnel)
# ============================================================
# Adresse recevant les notifications système (nouvelles candidatures, etc.)
NOTIFY_EMAIL_TO="recrutement@domipack.fr"

# ============================================================
# PROVIDER EMAIL — choisir 1 des 3 (le provider actif est aussi
# configurable depuis l'admin → Configuration → « Passerelles d'envoi »)
# ============================================================

# --- Resend (https://resend.com/api-keys) ---
EMAIL_RESEND_API_KEY=""

# --- Brevo / Sendinblue (https://app.brevo.com/settings/keys/api) ---
EMAIL_BREVO_API_KEY=""

# --- SMTP (recommandé pour production souveraine) ---
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_USER=""
EMAIL_SMTP_PASS=""

# ============================================================
# MODÈLE IA (optionnel — défaut : Ollama local sans clé)
# ============================================================
# Si provider IA distant (vLLM / OpenAI-compatible), renseigner la clé.
# Pour Ollama local (http://localhost:11434), laisser vide.
AI_API_KEY=""
